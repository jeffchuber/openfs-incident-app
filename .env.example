# Required — Anthropic API key for Claude chat
ANTHROPIC_API_KEY=sk-ant-...

# Dev mode (default) uses in-memory mock backends — no other config needed.
# Set to "production" to use real openfs mcp subprocess with live backends.
# OPENFS_MODE=production

# Production only — path to openfs binary (must be on $PATH or absolute)
# OPENFS_BINARY=openfs
# OPENFS_CONFIG=./openfs.yaml

# Production only — Supabase / Postgres
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Production only — S3-compatible object storage
# S3_BUCKET=my-bucket
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_ENDPOINT_URL_S3=https://s3.amazonaws.com
# AWS_REGION=us-east-1

# Production only — Chroma Cloud (semantic search)
# CHROMA_URL=api.trychroma.com
# CHROMA_API_KEY=...
# CHROMA_TENANT=...
# CHROMA_DATABASE=...
